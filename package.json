{
  "name": "erc20-pipe",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "avalanche": "bun src/main.ts avalanche",
    "eth": "bun src/main.ts eth",
    "immutablezkevm": "bun src/main.ts immutablezkevm",
    "monad": "bun src/main.ts monad",
    "pol": "bun src/main.ts pol",
    "all": "bun src/main.ts avalanche & bun src/main.ts eth & bun src/main.ts immutablezkevm & bun src/main.ts monad & bun src/main.ts pol & wait",
    "start": "bun typegen && bun all",
    "typegen": "squid-evm-typegen --clean src/abi ./abi/*.json",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "studio": "docker run --rm -p 3488:3488 --network template-pipe_default -e CLICKHOUSE_URL='http://clickhouse:8123' ghcr.io/caioricciuti/ch-ui:latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@subsquid/evm-typegen": "^4.6.0",
    "@subsquid/pipes": "^0.1.0-beta.16"
  }
}
